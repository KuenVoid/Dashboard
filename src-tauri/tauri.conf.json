{
  "productName": "DashBoard",
  "version": "0.1.0",
  "identifier": "com.dashboard.app",
  "app": {
    "windows": [
      {
        "title": "DashBoard",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {},
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  }
}